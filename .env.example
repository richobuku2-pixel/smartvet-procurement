# App base URL — used in password reset emails (set to your production domain)
VITE_APP_URL=https://smartvet-procurement.vercel.app

# Google OAuth (optional — enables Google Sign-In on the login page)
VITE_GOOGLE_CLIENT_ID=

# Zoho Mail — server-side only, used for password reset emails
ZOHO_FROM_EMAIL=hello@smartvet.africa
ZOHO_APP_PASSWORD=
